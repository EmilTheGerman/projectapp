<Window x:Class="passwordmanager.CategoriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Категорії"
        Height="400"
        Width="600"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">
    

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="{DynamicResource BgBrush}">
            <Button Content="Соцмережі" Click="Category_Click"/>
            <Button Content="Пошта" Click="Category_Click"/>
            <Button Content="Робота" Click="Category_Click"/>
        </StackPanel>

        <Border Grid.Column="1"
                Background="{DynamicResource CardBrush}"
                CornerRadius="10"
                Margin="10">

            <StackPanel Margin="10">

                <TextBlock x:Name="CategoryTitle"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="16"
                           FontWeight="Bold"/>

                <ListBox x:Name="CategoryList"
                         SelectionChanged="CategoryList_SelectionChanged"
                         Background="{DynamicResource CardBrush}"
                         BorderBrush="{DynamicResource BgBrush}">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource BgBrush}"
                                    Margin="5"
                                    Padding="8"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Login}"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>
        </Border>
    </Grid>
</Window>