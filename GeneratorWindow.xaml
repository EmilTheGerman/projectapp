<Window x:Class="passwordmanager.GeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Генератор"
        Height="350"
        Width="400"
        Background="{DynamicResource BgBrush}"
        WindowStartupLocation="CenterOwner">

    <Border Background="{DynamicResource CardBrush}"
            CornerRadius="10"
            Padding="15"
            Margin="10">

        <StackPanel>

            <TextBlock Text="Генератор паролів"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="16"
                       FontWeight="Bold"/>

            <TextBlock Text="Довжина"
                       Foreground="{DynamicResource TextBrush}"/>

            <Slider x:Name="LengthSlider" Minimum="6" Maximum="32" Value="12"/>

            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="UpperCheck" Content="A-Z"/>
                <CheckBox x:Name="LowerCheck" Content="a-z"/>
                <CheckBox x:Name="DigitCheck" Content="0-9"/>
                <CheckBox x:Name="SymbolCheck" Content="@#!$"/>
            </StackPanel>

            <TextBox x:Name="ResultBox" Margin="0,10"/>

            <StackPanel Orientation="Horizontal">
                <Button Content="Згенерувати"
                        Background="{DynamicResource AccentBrush}"
                        Click="Generate_Click"/>
                <Button Content="Використати"
                        Click="Use_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>