<Window
    x:Class="passwordmanager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Password Manager"
    Width="1000"
    Height="600"
    Background="{DynamicResource BgBrush}"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="#6C63FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="BorderBrush" Value="#DCDDE1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Grid>
        <Grid x:Name="MainPanel">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

            <StackPanel Background="{DynamicResource SidebarBrush}">

                <TextBlock
                Margin="10"
                FontSize="16"
                Foreground="White"
                Text="Password Manager" />

             <Button Click="ShowMain_Click" x:Name="BtnAll" Content="Усі записи"/>
            <Button Content="Категорії" Click="ShowCategories_Click"/>
            <Button Click="ShowGenerator_Click" Content="Генератор" />
            <Button Content="Налаштування" x:Name="BtnSettings" Click="ShowSettings_Click"/>

            </StackPanel>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

                <Grid Background="White">
                    <TextBlock Text="Пошук"/>
                    <TextBox
                    x:Name="SearchBox"
                    Width="250"
                    Height="30"
                    Margin="10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    TextChanged="SearchBox_TextChanged" />
                </Grid>

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}">
                        <ListBox x:Name="PasswordList" BorderThickness="0"
                                 SelectionChanged="PasswordList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBrush}"
                                    Margin="5"
                                    Padding="8"
                                    CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Login}" FontSize="12" Foreground="Gray"/>
                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="#6C63FF"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>

                        <TextBlock
                            Margin="5"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Дані запису" />

                            <TextBlock Text="Назва"/>
                            <TextBox x:Name="TitleBox"/>

                            <TextBlock Text="Логін"/>
                            <TextBox x:Name="LoginBox"/>

                            <TextBlock Text="Пароль"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <PasswordBox x:Name="PasswordBox"/>
                                <TextBox x:Name="PasswordTextBox" Visibility="Collapsed"/>

                                <Button Grid.Column="1"
                                 Content="👁"
                                 Click="TogglePassword_Click"/>
                            </Grid>

                            <TextBlock Text="Категорія"/>
                            <ComboBox x:Name="CategoryBox" Margin="5">
                                <ComboBoxItem Content="Соцмережі"/>
                                <ComboBoxItem Content="Пошта"/>
                                <ComboBoxItem Content="Робота"/>
                            </ComboBox>

                            <TextBlock Text="Опис"/>
                            <TextBox x:Name="DescriptionBox"
                             Height="60"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal">
                            <Button
                                Width="100"
                                Click="Save_Click"
                                Background="{DynamicResource AccentBrush}"
                                Content="Зберегти" />

                            <Button
                                Width="100"
                                Background="#FF4757"
                                Click="Delete_Click"
                                Content="Видалити" />
                        </StackPanel>

                    </StackPanel>
                </Border>

            </Grid>

        </Grid>

    </Grid>
        <Grid x:Name="GeneratorPanel" Visibility="Collapsed">

            <Border Style="{StaticResource Card}"
            Width="400"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Генератор паролів"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="5"/>

                    <TextBlock Text="Довжина:"/>
                    <Slider x:Name="LengthSlider" Minimum="6" Maximum="32" Value="12"/>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="UpperCheck" Content="A-Z" IsChecked="True"/>
                        <CheckBox x:Name="LowerCheck" Content="a-z" IsChecked="True"/>
                        <CheckBox x:Name="DigitCheck" Content="0-9" IsChecked="True"/>
                        <CheckBox x:Name="SymbolCheck" Content="@#!$" IsChecked="True"/>
                    </StackPanel>

                    <TextBox x:Name="GeneratedPasswordBox"
                     Height="35"
                     Margin="0,10"
                     FontSize="16"
                     HorizontalContentAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Згенерувати" Click="Generate_Click"/>
                        <Button Content="Копіювати" Click="Copy_Click"/>
                    </StackPanel>

                    <Button Content="Назад"
                    Background="#57606f"
                    Click="ShowMain_Click"/>

                </StackPanel>
            </Border>
        </Grid>
        <Grid x:Name="CategoriesPanel" Visibility="Collapsed">

            <Border Style="{StaticResource Card}"
            Width="500"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Background="#F1F2F6" Margin="5">

                        <TextBlock Text="Категорії"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="5"/>

                        <Button Content="Соцмережі" Click="Category_Click"/>
                        <Button Content="Пошта" Click="Category_Click"/>
                        <Button Content="Робота" Click="Category_Click"/>

                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10">

                        <TextBlock x:Name="CategoryTitle"
                           Text="Оберіть категорію"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="5"/>

                        <ListBox x:Name="CategoryList" BorderThickness="0"
                                  SelectionChanged="CategoryList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F1F2F6"
                                     Margin="5"
                                     Padding="8"
                                     CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Login}" FontSize="12" Foreground="Gray"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Content="Назад"
                        Background="#57606f"
                        Click="ShowMain_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Grid x:Name="SettingsPanel" Visibility="Collapsed">

            <Border Style="{StaticResource Card}"
            Width="400"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock Text="Налаштування"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="5"/>

                    <TextBlock Text="Тема"/>
                    <ComboBox x:Name="ThemeBox" Margin="5">
                        <ComboBoxItem Content="Світла"/>
                        <ComboBoxItem Content="Темна"/>
                    </ComboBox>

                    <Button Content="Застосувати"
                    Click="ApplySettings_Click"/>

                    <Button Content="⬅ Назад"
                    Background="#57606f"
                    Click="ShowMain_Click"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>     
</Window>
